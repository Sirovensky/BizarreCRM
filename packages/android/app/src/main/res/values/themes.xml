<resources>
    <!--
        Parent changed from android:Theme.Material.Light.NoActionBar (causes white
        flash before Compose mounts) to Theme.AppCompat.DayNight.NoActionBar.
        This is the standard parent for Compose-only apps — it provides DayNight
        support without inflating any view-based Material chrome.
        windowBackground is set to the warm near-black brand dark bg (#121017) so
        the launch frame is on-brand instead of a white flash.
    -->
    <style name="Theme.BizarreCRM" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">#121017</item>
    </style>
</resources>
