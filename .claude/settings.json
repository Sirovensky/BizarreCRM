{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/block-no-verify.js",
            "description": "Block --no-verify / -c core.hooksPath= from git commands"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-bash-commit-quality.js",
            "description": "Pre-commit quality gate (lint + secrets scan)"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/config-protection.js",
            "description": "Block edits to tsconfig / eslint / prettier / package.json engines — steer fixes toward code"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-edit-typecheck.js",
            "description": "Run tsc --noEmit after .ts/.tsx edits"
          }
        ]
      }
    ]
  }
}
