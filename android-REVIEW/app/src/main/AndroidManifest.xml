<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- CAMERA: required for the runtime permission request in PhotoCaptureScreen.
         The screen calls ActivityResultContracts.RequestPermission(CAMERA) so the
         user can pre-authorize the hardware before a future CameraX live-capture
         surface ships. Without this manifest declaration Android silently denies
         the request and never shows the system dialog, so the user sees only a
         rationale dialog but never the actual permission prompt (bug:camera-perms).
         The gallery-picker path (GetContent) does NOT require CAMERA at runtime;
         this declaration only enables the permission-request dialog. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- M4 fix: CALL_PHONE was declared but never used. CustomerDetailScreen
         and TicketDetailScreen both use Intent.ACTION_DIAL, which opens the
         system dialer and does NOT require CALL_PHONE. Removing the dead
         permission avoids a false Play Store review flag. -->

    <!-- Vibrate (barcode scan feedback) -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Foreground service — base permission (required for all FGS on any API level) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- FOREGROUND_SERVICE_DATA_SYNC: required on API 34+ for RepairInProgressService
         which uses foregroundServiceType="dataSync" in startForeground(). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- FOREGROUND_SERVICE_MEDIA_PLAYBACK: required for CallNotificationService
         which uses foregroundServiceType="mediaPlayback" (§42 call audio). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <!-- FOREGROUND_SERVICE_PHONE_CALL: API 34+ — required for the phoneCall
         foreground-service type used by CallNotificationService on API 34+. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_PHONE_CALL" />

    <!-- POST_NOTIFICATIONS: runtime permission required on API 33+ to show any
         notification (FCM alerts, RepairInProgress pinned notification, etc.).
         Must be granted at runtime; declare here so the system shows the prompt. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- BLUETOOTH_CONNECT + BLUETOOTH_SCAN: API 31+ runtime permissions for
         Bluetooth device pairing / discovery (e.g. receipt printer, barcode scanner).
         neverForLocation flag: scanning is not used to derive location — required
         by Play Store policy to avoid the location-permission disclosure requirement. -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_CONNECT"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />

    <!-- ACCESS_FINE_LOCATION: used for Wi-Fi-based LAN IP detection and optional
         geo-tagging of customer records. No maxSdkVersion cap — needed on all
         supported API levels. Runtime grant required; gated in code for optional paths. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <!-- RECORD_AUDIO: runtime permission for future voice-memo or VoIP features.
         Declared now so the manifest is complete; runtime prompt is gated in code. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- READ_CONTACTS: runtime permission for autofill / customer lookup from
         the device address book. Declared here; prompt shown in feature code. -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <!-- Biometric -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <!-- READ_MEDIA_IMAGES: runtime permission for photo gallery access on API 33+.
         No maxSdkVersion — the permission only exists on API 33+ so it is
         harmless to declare without a cap. The system denies it silently on
         API ≤32 anyway; READ_EXTERNAL_STORAGE (below) covers that range. -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <!-- READ_EXTERNAL_STORAGE: legacy gallery read permission for API ≤32.
         maxSdkVersion=32 prevents this from appearing on API 33+ devices
         where READ_MEDIA_IMAGES supersedes it. -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Package-visibility declarations (Android 11+ / API 30+).
         Without these entries the OS hides matching apps from queryIntentActivities
         and Intent.resolveActivity returns null, breaking ACTION_DIAL, ACTION_SENDTO,
         ACTION_VIEW(geo), and ACTION_SENDTO(mailto) implicit intents. -->
    <queries>
        <!-- Phone dialer — used in CustomerDetailScreen / TicketDetailScreen -->
        <intent>
            <action android:name="android.intent.action.DIAL" />
            <data android:scheme="tel" />
        </intent>
        <!-- SMS / MMS apps — used for customer SMS shortcuts -->
        <intent>
            <action android:name="android.intent.action.SENDTO" />
            <data android:scheme="smsto" />
        </intent>
        <!-- Maps / navigation — used for customer address shortcuts -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="geo" />
        </intent>
        <!-- Email client — used for customer email shortcuts -->
        <intent>
            <action android:name="android.intent.action.SENDTO" />
            <data android:scheme="mailto" />
        </intent>
        <!-- Calendar app — used by CalendarMirror.addToCalendar (Intent.ACTION_INSERT).
             Declared here so resolveActivity() returns non-null on API 30+ without
             requiring READ_CALENDAR / WRITE_CALENDAR runtime permissions. The intent
             approach lets the user's calendar app handle insertion; no permission prompt
             is shown to the user by the CRM itself. -->
        <intent>
            <action android:name="android.intent.action.INSERT" />
            <data android:mimeType="vnd.android.cursor.dir/event" />
        </intent>

        <!-- §68.5 outbound ACTION_SEND targets: PDF, CSV, vCard, image share.
             createChooser() works without these entries, but resolveActivity()
             and queryIntentActivities() require them on API 30+ if the app ever
             needs to verify a share target exists before opening the chooser.
             Declaring all four MIME types here keeps the queries block consistent
             with all MIME types the app may share outbound. -->
        <intent>
            <action android:name="android.intent.action.SEND" />
            <data android:mimeType="application/pdf" />
        </intent>
        <intent>
            <action android:name="android.intent.action.SEND" />
            <data android:mimeType="text/csv" />
        </intent>
        <intent>
            <action android:name="android.intent.action.SEND" />
            <data android:mimeType="text/x-vcard" />
        </intent>
        <intent>
            <action android:name="android.intent.action.SEND" />
            <data android:mimeType="image/*" />
        </intent>
    </queries>

    <application
        android:name=".BizarreCrmApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.BizarreCRM"
        android:networkSecurityConfig="@xml/network_security_config"
        android:localeConfig="@xml/locales_config"
        android:enableOnBackInvokedCallback="true"
        android:extractNativeLibs="false">

        <!--
            §71.1 SplashScreen API: the dedicated Theme.BizarreCRM.Splash theme
            exists in res/values/themes.xml but cannot be applied to MainActivity
            until installSplashScreen() is called inside MainActivity.onCreate
            (before super.onCreate). Without that call, Theme.SplashScreen leaves
            the activity stuck on its launch chrome — including a title bar
            showing the app label — covering the actual content. Until the
            installSplashScreen() wiring lands (deferred per ActionPlan §71.1
            "Keep-on-screen condition"), MainActivity stays on Theme.BizarreCRM.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.BizarreCRM"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation">
            <!-- §22 L2251 — minimum window size for freeform / desktop windowing.
                 ChromeOS and Samsung DeX honour these constraints.
                 400×560 dp chosen to fit the compact ticket list + bottom nav comfortably. -->
            <layout
                android:minWidth="400dp"
                android:minHeight="560dp" />
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- HTTPS deep-link filter with autoVerify=true.
                 Android App Links verification requires a companion
                 /.well-known/assetlinks.json hosted on the server.
                 TODO(AUDIT-AND-019): add GET /.well-known/assetlinks.json
                 route to packages/server — until that route is live, OS
                 verification will fail silently and the link will fall back
                 to the browser. autoVerify=true is still the correct
                 declaration; it causes no harm while the JSON is absent. -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="bizarrecrm.app" />
            </intent-filter>

            <!-- App Links for the tenant subdomain app.bizarrecrm.com (plan §1.5 L205).
                 Kept as a separate filter block from bizarrecrm.app above — the OS
                 verifies each autoVerify filter independently; merging hosts into one
                 filter causes verification to fail if either domain is unreachable.
                 Server-side: deploy /.well-known/assetlinks.json at
                 https://app.bizarrecrm.com — see TODO.md CROSS-PLATFORM section.
                 Until assetlinks.json is live, links open in the browser (safe fallback). -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="app.bizarrecrm.com" />
            </intent-filter>

            <!-- Custom-scheme filter for internal use (launcher shortcuts,
                 local notifications). android:exported="false" cannot be set
                 on an intent-filter directly — the parent activity is already
                 exported=true for the MAIN/LAUNCHER filter above. Custom
                 schemes are not App Links so no autoVerify is needed here. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="bizarrecrm" />
            </intent-filter>

            <!-- §2.7 L330 — Setup-token App Link: HTTPS on both the bare domain and
                 the app subdomain so either invite URL works.
                 autoVerify=true causes the OS to verify the domain via
                 /.well-known/assetlinks.json; falls back to browser until that
                 route is deployed (TODO: see AUDIT-AND-019).
                 Kept as two separate autoVerify filters — see existing reset-password
                 comment above for why merging hosts breaks domain verification. -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="bizarrecrm.com" android:pathPrefix="/setup/" />
                <data android:scheme="https" android:host="app.bizarrecrm.com" android:pathPrefix="/setup/" />
            </intent-filter>

            <!-- §2.7 L330 — Custom-scheme variant: bizarrecrm://setup/<token>
                 for internal use (QR codes, email deep links in test environments). -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="bizarrecrm" android:host="setup" />
            </intent-filter>

            <!-- §2.20 L448 — SSO callback intent filter.
                 Chrome Custom Tabs redirect the IdP back to:
                   bizarrecrm://sso/callback?code=<auth-code>&state=<csrf-state>
                 MainActivity.resolveDeepLink recognises this host+path and dispatches
                 code + state to DeepLinkBus.publishSsoResult for token exchange.
                 pathPrefix="/callback" ensures only the callback path is handled. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="bizarrecrm" android:host="sso" android:pathPrefix="/callback" />
            </intent-filter>

            <!-- §2.21 L454 — Magic-link App Link: https://app.bizarrecrm.com/magic/<token>
                 autoVerify=true causes the OS to verify /.well-known/assetlinks.json on
                 app.bizarrecrm.com; falls back to browser until that route is deployed
                 (same TODO as AUDIT-AND-019 for setup-token). Kept as a separate filter
                 from the generic app.bizarrecrm.com filter to scope the pathPrefix tightly.
                 MainActivity.resolveDeepLink validates the token via DeepLinkAllowlist and
                 publishes it to DeepLinkBus.publishMagicLinkToken for VM-side exchange. -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="app.bizarrecrm.com" android:pathPrefix="/magic/" />
            </intent-filter>

            <!-- §2.21 L454 — Magic-link custom-scheme variant: bizarrecrm://magic/<token>
                 Used in QR codes, test-environment email links, and as a fallback when
                 App Link verification has not yet completed on the device. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="bizarrecrm" android:host="magic" />
            </intent-filter>

            <!-- §55.1 — Public tracking App Link: https://app.bizarrecrm.com/t/:orderId
                 Customer-facing repair-status deep link (SMS / email / QR code).
                 autoVerify=true triggers /.well-known/assetlinks.json verification on
                 app.bizarrecrm.com; falls back to browser until the domain is verified.
                 The NavHost composable extracts orderId + token query param. -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="app.bizarrecrm.com" android:pathPrefix="/t/" />
            </intent-filter>

            <!-- §55.1 — Public tracking custom-scheme variant: bizarrecrm://track/:orderId
                 Used in QR labels printed for customer repair bags (§55.3). -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="bizarrecrm" android:host="track" />
            </intent-filter>

            <!--
              §25.2 Inbound share — other apps can share text, images, and
              PDFs into BizarreCRM. The system shows our app in the chooser
              when the sender's MIME type matches one of these filters.
              MainActivity.resolveInboundShare() inspects the incoming intent
              and routes it to "Attach to ticket" / "New note" picker flow.

              Three separate intent-filter blocks are required because a single
              filter with multiple <data> MIME types would require ALL types to
              match simultaneously. One filter per type is the correct pattern.
            -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/pdf" />
            </intent-filter>

            <!-- Static shortcuts + App Actions metadata. -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />

            <!-- §24.5 — App Actions (Capabilities API) declarations.
                 Maps BIIs (actions.intent.CREATE_MESSAGE, GET_RESERVATION) to
                 deep-link URI templates in res/xml/actions.xml.
                 Assistant resolves these to navigate into the app. -->
            <meta-data
                android:name="android.app.actions"
                android:resource="@xml/actions" />
        </activity>

        <!--
          §56.4 — Optional Android TV / Google TV launcher entry for shop big-screen
          displays using dedicated Fire TV or Android TV sticks.

          An <activity-alias> is used so the TV board launches directly into
          MainActivity with a deep-link extra rather than declaring a separate Activity.
          The LEANBACK_LAUNCHER category makes this icon appear in the Android TV /
          Google TV home row. The banner drawable (@drawable/tv_banner) is required by
          the Leanback launcher; it must be 320×180 dp as specified in the TV design
          guidelines. The alias is exported=true so the TV launcher can start it;
          it will only appear on Leanback-capable devices.

          Note: the alias target (MainActivity) handles the bizarrecrm://tvqueue deep link
          in resolveDeepLink() → routes to Screen.TvQueueBoard.
        -->
        <activity-alias
            android:name=".TvQueueBoardActivity"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:label="@string/screen_tv_queue_board"
            android:banner="@drawable/tv_banner">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
            <!-- Deep link so MainActivity routes straight to the TV queue board. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="bizarrecrm" android:host="tvqueue" />
            </intent-filter>
        </activity-alias>

        <!-- Firebase Messaging Service -->
        <service
            android:name=".service.FcmService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Foreground service used for the Live-Activity-style pinned
             "Repair in progress" notification. foregroundServiceType must
             match the category declared when startForeground is called. -->
        <service
            android:name=".service.RepairInProgressService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

        <!-- §42 — In-progress call Activity. supportsPictureInPicture=true lets
             the user swipe home while on a call and continue in PiP mode.
             launchMode=singleTop prevents stacking multiple CallInProgress instances
             from rapid FCM pushes. showOnLockScreen: call UI visible on lock screen.
             configChanges mirrors MainActivity to survive rotation. -->
        <activity
            android:name=".ui.screens.calls.CallInProgressActivity"
            android:exported="false"
            android:supportsPictureInPicture="true"
            android:launchMode="singleTop"
            android:showOnLockScreen="true"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation" />

        <!-- §42 — Foreground service that shows the active-call notification.
             foregroundServiceType="mediaPlayback|phoneCall":
               mediaPlayback — audio output associated with the server-bridged call.
               phoneCall     — required on API 34+ for telephony-category FGS.
             exported=false: only this app's process starts the service. -->
        <service
            android:name=".service.CallNotificationService"
            android:foregroundServiceType="mediaPlayback|phoneCall"
            android:exported="false" />

        <!-- Quick Settings tile (Android 7+). BIND_QUICK_SETTINGS_TILE is
             the system-owned permission that protects the binding — apps
             never request it themselves. -->
        <service
            android:name=".service.QuickTicketTileService"
            android:label="@string/shortcut_new_ticket_short"
            android:icon="@mipmap/ic_launcher"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- Home-screen widget provider. exported=true is required so the
             launcher process can bind to the provider. -->
        <receiver
            android:name=".widget.DashboardWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>

        <!-- §1.6 / §24 plan:L225,L2316 — Glance Unread-SMS home-screen widget.
             exported=false: only the system AppWidget framework (platform cert)
             sends ACTION_APPWIDGET_UPDATE — no other app can reach this receiver.
             GlanceAppWidgetReceiver handles all standard lifecycle broadcasts
             (UPDATE / ENABLED / DISABLED / DELETED) internally. -->
        <receiver
            android:name=".widget.glance.UnreadSmsGlanceReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/glance_unread_sms_info" />
        </receiver>

        <!-- §24.1 — Glance Clock-In/Out home-screen widget. -->
        <receiver
            android:name=".widget.glance.ClockInGlanceReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/glance_clock_in_info" />
        </receiver>

        <!-- §24.1 — Glance Low-Stock home-screen widget. -->
        <receiver
            android:name=".widget.glance.LowStockGlanceReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/glance_low_stock_info" />
        </receiver>

        <!-- §24.1 — Glance Today's Revenue home-screen widget. -->
        <receiver
            android:name=".widget.glance.TodayRevenueGlanceReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/glance_today_revenue_info" />
        </receiver>

        <!-- §24.4 — Quick Settings tile: Clock In/Out.
             BIND_QUICK_SETTINGS_TILE is the system-owned permission protecting
             the binding — apps never declare it, only the OS grants it. -->
        <service
            android:name=".service.ClockInTileService"
            android:label="@string/tile_clock_in_label"
            android:icon="@mipmap/ic_launcher"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- §24.7 — Widget config activity launched by launcher on widget add.
             exported=true is required so the launcher process can start it.
             The activity sets RESULT_CANCELED immediately on create and RESULT_OK
             only after the user confirms — this prevents widget placement if the
             user backs out. -->
        <activity
            android:name=".widget.WidgetConfigActivity"
            android:exported="true"
            android:theme="@style/Theme.BizarreCRM"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <!-- §1.7 L245 — BroadcastReceiver for notification action buttons (Reply, Mark as read). -->
        <receiver android:name=".service.NotificationActionReceiver" android:exported="false" />

        <!-- §2.4 L302 — SMS Retriever OTP autofill receiver.
             android:exported="true" is required so Play Services can deliver
             the SMS_RETRIEVED_ACTION intent. The system permission below
             ensures only Play Services (not rogue apps) can send this intent. -->
        <receiver
            android:name=".util.SmsOtpBroadcastReceiver"
            android:exported="true"
            android:permission="com.google.android.gms.auth.api.phone.permission.SEND">
            <intent-filter>
                <action android:name="com.google.android.gms.auth.api.phone.SMS_RETRIEVED" />
            </intent-filter>
        </receiver>

        <!-- §32.3: FileProvider for sharing crash-report log files from
             filesDir/crash-reports via the system share-sheet. Authority is
             ${applicationId}.fileprovider; mapped paths live in
             res/xml/file_paths.xml (only crash-reports/ exposed). -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Disable the default WorkManager initializer — we use on-demand
             initialization via BizarreCrmApp (which implements Configuration.Provider). -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
