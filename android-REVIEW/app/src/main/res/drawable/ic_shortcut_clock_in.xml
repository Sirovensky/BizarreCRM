<?xml version="1.0" encoding="utf-8"?>
<!--
    Launcher shortcut icon — §24.3 Clock In / Out.

    Clock face with hands pointing to 9 o'clock (start of shift).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Background circle -->
    <path
        android:fillColor="#121017"
        android:pathData="M54,12 A42,42 0 1,1 54,96 A42,42 0 1,1 54,12 Z" />

    <!-- Clock face ring -->
    <path
        android:fillColor="#FDEED0"
        android:pathData="
            M54,28 A26,26 0 1,1 54,80 A26,26 0 1,1 54,28 Z
            M54,32 A22,22 0 1,0 54,76 A22,22 0 1,0 54,32 Z" />

    <!-- Hour hand (pointing left — 9 o'clock) -->
    <path
        android:fillColor="#FDEED0"
        android:pathData="M54,52 L38,54 L38,52 Z" />

    <!-- Minute hand (pointing up — 12 o'clock) -->
    <path
        android:fillColor="#FDEED0"
        android:pathData="M52,54 L54,38 L56,54 Z" />

    <!-- Center dot -->
    <path
        android:fillColor="#FDEED0"
        android:pathData="M52,52 A2,2 0 1,1 52,56 A2,2 0 1,1 52,52 Z" />

</vector>
