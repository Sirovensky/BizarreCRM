<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!--
      §32.3 — exposes filesDir/crash-reports/ via FileProvider so the
      Settings → Crash reports screen can share log files via the system
      share-sheet without using world-readable storage. The "files-path"
      root maps to Context.getFilesDir(). Subdir is restricted; nothing
      else under filesDir leaks.
    -->
    <files-path
        name="crash-reports"
        path="crash-reports/" />

    <!--
      POS-RECEIPT-RE-AUDIT — exposes cacheDir/receipts/ so PosReceiptViewModel
      can render a PDF to a File and share it via ACTION_SEND without needing
      world-readable storage. "cache-path" root maps to Context.getCacheDir().
    -->
    <cache-path
        name="receipts"
        path="receipts/" />
</paths>
