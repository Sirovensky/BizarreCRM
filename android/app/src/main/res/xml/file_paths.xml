<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!--
      §32.3 — exposes filesDir/crash-reports/ via FileProvider so the
      Settings → Crash reports screen can share log files via the system
      share-sheet without using world-readable storage. The "files-path"
      root maps to Context.getFilesDir(). Subdir is restricted; nothing
      else under filesDir leaks.
    -->
    <files-path
        name="crash-reports"
        path="crash-reports/" />

    <!--
      §32.4 — exposes filesDir/diagnostics-logs/ via FileProvider so
      Settings → Diagnostics → View logs can share the flushed ring-buffer
      file via the system share-sheet without world-readable storage.
      "files-path" root maps to Context.getFilesDir().
    -->
    <files-path
        name="diagnostics-logs"
        path="diagnostics-logs/" />

    <!--
      POS-RECEIPT-RE-AUDIT — exposes cacheDir/receipts/ so PosReceiptViewModel
      can render a PDF to a File and share it via ACTION_SEND without needing
      world-readable storage. "cache-path" root maps to Context.getCacheDir().
    -->
    <cache-path
        name="receipts"
        path="receipts/" />

    <!--
      §25.2 — exposes cacheDir/workorder/ so TicketPrintActions can share
      work-order PDFs via ACTION_SEND without world-readable storage. The root
      is already shared by the existing "receipts" entry; "workorder" is a
      separate path to keep concerns distinct.
      Also exposes cacheDir/photos/ for any locally-cached photo bitmaps
      that need to be shared out via ACTION_SEND / ACTION_SEND_MULTIPLE.
    -->
    <cache-path
        name="workorder"
        path="workorder/" />
    <cache-path
        name="photos"
        path="photos/" />

    <!--
      §6.7 — exposes cacheDir/purchase-orders/ via FileProvider so
      PurchaseOrderSendActions can share generated PO PDFs via PrintManager
      / ACTION_SEND without world-readable storage.
    -->
    <cache-path
        name="purchase-orders"
        path="purchase-orders/" />
</paths>
