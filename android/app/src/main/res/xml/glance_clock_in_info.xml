<?xml version="1.0" encoding="utf-8"?>
<!--
  AppWidgetProvider metadata for ClockInGlanceWidget / ClockInGlanceReceiver.

  - minWidth  110dp  ≈ 2 grid cells.
  - minHeight  40dp  ≈ 1 grid row.
  - resizeMode horizontal|vertical — user can expand to see employee name.
  - updatePeriodMillis 1800000 = 30 min system-polling fallback; live updates
    come via publishClockState() called on each successful API toggle.
  - configure: WidgetConfigActivity lets the user choose tenant on first add.
  - description: widget_clock_in_description (existing string, do not remove).
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="110dp"
    android:minHeight="40dp"
    android:minResizeWidth="110dp"
    android:minResizeHeight="40dp"
    android:updatePeriodMillis="1800000"
    android:initialLayout="@layout/widget_dashboard"
    android:previewImage="@drawable/glance_preview_clock_in"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:configure="com.bizarreelectronics.crm.widget.WidgetConfigActivity"
    android:description="@string/widget_clock_in_description" />
