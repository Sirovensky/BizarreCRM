<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- CAMERA permission removed (AND-020). BarcodeScanScreen is manual-entry
         only and PhotoCaptureScreen uses ActivityResultContracts.GetContent
         (gallery picker) which does NOT require CAMERA. When a real CameraX
         live-capture flow ships, re-add this permission and gate runtime
         requests behind shouldShowRequestPermissionRationale + a rationale
         dialog before ActivityResultContracts.RequestPermission. -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- M4 fix: CALL_PHONE was declared but never used. CustomerDetailScreen
         and TicketDetailScreen both use Intent.ACTION_DIAL, which opens the
         system dialer and does NOT require CALL_PHONE. Removing the dead
         permission avoids a false Play Store review flag. -->

    <!-- Vibrate (barcode scan feedback) -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Foreground service (WebSocket) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Biometric -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <!-- Storage for cached images (API 33 only; SDK 33+ uses photo picker which needs no permission) -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"
        android:maxSdkVersion="32" />

    <application
        android:name=".BizarreCrmApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.BizarreCRM"
        android:networkSecurityConfig="@xml/network_security_config">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.BizarreCRM"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- HTTPS deep-link filter with autoVerify=true.
                 Android App Links verification requires a companion
                 /.well-known/assetlinks.json hosted on the server.
                 TODO(AUDIT-AND-019): add GET /.well-known/assetlinks.json
                 route to packages/server — until that route is live, OS
                 verification will fail silently and the link will fall back
                 to the browser. autoVerify=true is still the correct
                 declaration; it causes no harm while the JSON is absent. -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="bizarrecrm.app" />
            </intent-filter>

            <!-- Custom-scheme filter for internal use (launcher shortcuts,
                 local notifications). android:exported="false" cannot be set
                 on an intent-filter directly — the parent activity is already
                 exported=true for the MAIN/LAUNCHER filter above. Custom
                 schemes are not App Links so no autoVerify is needed here. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="bizarrecrm" />
            </intent-filter>

            <!-- Static shortcuts + App Actions metadata. -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <!-- Firebase Messaging Service -->
        <service
            android:name=".service.FcmService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Foreground service used for the Live-Activity-style pinned
             "Repair in progress" notification. foregroundServiceType must
             match the category declared when startForeground is called. -->
        <service
            android:name=".service.RepairInProgressService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

        <!-- Quick Settings tile (Android 7+). BIND_QUICK_SETTINGS_TILE is
             the system-owned permission that protects the binding — apps
             never request it themselves. -->
        <service
            android:name=".service.QuickTicketTileService"
            android:label="@string/shortcut_new_ticket_short"
            android:icon="@mipmap/ic_launcher"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- Home-screen widget provider. exported=true is required so the
             launcher process can bind to the provider. -->
        <receiver
            android:name=".widget.DashboardWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>

        <!-- §32.3: FileProvider for sharing crash-report log files from
             filesDir/crash-reports via the system share-sheet. Authority is
             ${applicationId}.fileprovider; mapped paths live in
             res/xml/file_paths.xml (only crash-reports/ exposed). -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Disable the default WorkManager initializer — we use on-demand
             initialization via BizarreCrmApp (which implements Configuration.Provider). -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
