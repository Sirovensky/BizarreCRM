# §33.11 — Fastlane Appfile for BizarreCRM Android
#
# json_key_file: path to the Google Play service-account JSON key.
#   Generate at: Play Console → Setup → API access → Service accounts.
#   Store outside the repo; pass via SUPPLY_JSON_KEY env var in CI or
#   set the path below for local runs.
#
# NOTE: Do NOT commit the key file. Reference it by path or env var only.

json_key_file(ENV["SUPPLY_JSON_KEY"] || File.expand_path("~/.android-keystores/bizarrecrm-play-key.json"))
package_name("com.bizarreelectronics.crm")
