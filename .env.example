# ─── Server-Level Config (shared across all tenants) ─────────────────
PORT=3020
HOST=0.0.0.0
NODE_ENV=development

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-random-string
JWT_REFRESH_SECRET=change-me-to-another-random-string

# ─── Multi-Tenancy (optional) ─────────────────────────────────────────
# MULTI_TENANT=true
# BASE_DOMAIN=bizarrecrm.com
# SUPER_ADMIN_SECRET=change-me-in-production
# SUPER_ADMIN_EMAIL=admin@bizarrecrm.com
# SUPER_ADMIN_PASSWORD=change-me

# ─── Per-Tenant Settings ──────────────────────────────────────────────
# All shop-specific config (store name, phone, email, SMTP, SMS provider,
# RepairDesk API key, BlockChyp keys, 3CX credentials) is stored in each
# tenant's database via the Settings UI.
# NO per-tenant secrets belong in this file.
