# ─── Server-Level Config (shared across all tenants) ─────────────────
PORT=443
HOST=0.0.0.0
# Set to "production" on your live server, "development" locally.
NODE_ENV=

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-random-string
JWT_REFRESH_SECRET=change-me-to-another-random-string

# SA1-1: Graceful JWT secret rotation. When rotating JWT_SECRET, set the OLD
# value here as _PREVIOUS so existing sessions keep verifying until their
# tokens expire. Remove these lines and restart again once access-token TTL
# (1h) plus a safety buffer (~30min) has elapsed — any sessions that haven't
# refreshed in that window will be forced to re-authenticate, which is the
# intended effect of a rotation. See docs/operator-guide.md for the full
# procedure.
# JWT_SECRET_PREVIOUS=
# JWT_REFRESH_SECRET_PREVIOUS=

# @audit-fixed: #15 — dedicated backup encryption key. Decouples encrypted
# backups from JWT_SECRET rotation so rotating JWT_SECRET does NOT permanently
# brick every encrypted .db.enc file on disk. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# If unset, the backup service falls back to JWT_SECRET for backward compat
# (and logs a one-time warning at boot). Strongly recommended in production.
# BACKUP_ENCRYPTION_KEY=

# @audit-fixed: #13 — Vonage Messages API webhook signature secret. Used to
# verify the HS256 JWT in the Authorization header of inbound/status webhooks.
# Found in the Vonage dashboard under Settings → Signature Secret. If unset,
# the provider falls back to the signatureSecret stored in the per-tenant
# store_config row (set via the Settings UI).
# VONAGE_SIGNATURE_SECRET=

# ─── Multi-Tenancy (optional) ─────────────────────────────────────────
# MULTI_TENANT=true
# BASE_DOMAIN=example.com
# SUPER_ADMIN_SECRET=change-me-in-production
# SUPER_ADMIN_EMAIL=admin@example.com
# SUPER_ADMIN_PASSWORD=change-me
#
# Public signup CAPTCHA. If HCAPTCHA_SECRET is omitted, signups remain open
# and the server logs security alerts; set both values to enforce hCaptcha.
# VITE_HCAPTCHA_SITE_KEY=
# HCAPTCHA_SECRET=

# ─── Stripe Billing (PLATFORM subscription billing only) ─────────────
# SCOPE: These credentials belong to the CRM PLATFORM OPERATOR (you), not to
# tenants. They are used ONLY for charging tenant shops for their CRM
# subscription (Pro/Enterprise tiers) via /api/v1/billing/* and the platform
# Stripe webhook handler in services/stripe.ts.
#
# These keys are NOT used to charge tenants' end customers (repair clients).
# Tenants bring their own payment processing for their customers — currently
# BlockChyp is wired per-tenant via store_config. Any future tenant-level
# Stripe integration (so a tenant can run Stripe Checkout against THEIR OWN
# Stripe account) MUST read its keys from the tenant DB's store_config, not
# from these env vars. Mixing platform Stripe with tenant Stripe creates
# liability leakage — a tenant's chargeback hitting the platform account.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# ─── Cloudflare DNS — REQUIRED FOR AUTO-DNS ──────────────────────────
# ████████████████████████████████████████████████████████████████████
# █  REQUIRED in production multi-tenant mode with a real BASE_DOMAIN. █
# █  Without these, signups succeed but the new subdomain will NOT    █
# █  resolve and users get "Server Not Found" errors (see 2026-04-10  █
# █  newshop.bizarrecrm.com incident). Server logs a loud warning at  █
# █  startup if multi-tenant is on, BASE_DOMAIN is real, and these    █
# █  are empty.                                                       █
# █                                                                   █
# █  Optional ONLY in dev / single-tenant / BASE_DOMAIN=localhost.    █
# ████████████████████████████████████████████████████████████████████
# Creates a proxied A record per tenant shop via the Cloudflare API so that
# {slug}.{BASE_DOMAIN} resolves automatically when a shop is provisioned.
# Token must have Zone.DNS:Edit permission scoped to your zone ONLY.
# Create at: Cloudflare dashboard > My Profile > API Tokens > Create Token > Custom token
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
SERVER_PUBLIC_IP=

# ─── Per-Tenant Settings ──────────────────────────────────────────────
# All shop-specific config (store name, phone, email, SMTP, SMS/MMS provider,
# RepairDesk API key, BlockChyp keys, provider credentials) is stored in each
# tenant's database via the Settings UI.
# NO per-tenant secrets belong in this file.

# ─── Logging ──────────────────────────────────────────────────────────
# LOG_LEVEL: error|warn|info|debug (default: info)
# LOG_FORMAT: "text" for pretty output, anything else = JSON (default: json)
# LOG_INCLUDE_STACKS: "true" to include stack traces in prod error logs
# LOG_LEVEL=info
# LOG_FORMAT=json
# LOG_INCLUDE_STACKS=false

# ─── CORS / Network ───────────────────────────────────────────────────
# Comma-separated list of extra allowed origins beyond the computed defaults.
# ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
# Comma-separated list of trusted reverse-proxy IPs (sets Express trust proxy).
# TRUSTED_PROXY_IPS=

# ─── Audit Log Retention ──────────────────────────────────────────────
# How many days to retain audit_logs rows before the pruner deletes them.
# Default: 730 (2 years). Set to a larger value for compliance regimes.
# AUDIT_LOG_RETENTION_DAYS=730

# ─── Supplier Catalog Scraper ─────────────────────────────────────────
# Timezone used to decide when the nightly Mobilesentrix/PhoneLcdParts
# scrape runs. Default: America/Denver.
# SUPPLIER_SCRAPE_TIMEZONE=America/Denver

# ─── ClamAV (optional virus scanning on uploads) ──────────────────────
# If CLAMAV_HOST is set, uploaded files are scanned via clamd TCP.
# CLAMAV_HOST=
# CLAMAV_PORT=3310

# ─── Dev-only helpers (NEVER set in production) ───────────────────────
# In multi-tenant dev mode, resolves bare-IP / localhost requests to this
# tenant slug so you can hit the CRM without a subdomain.
# DEV_TENANT_SLUG=
# Master-admin legacy /admin endpoints are disabled by default. Set to
# "true" only on machines that still need the old HTML admin panel.
# MASTER_ADMIN_LEGACY_ENABLED=false

# ─── Stripe Billing (Enterprise tier, optional) ───────────────────────
# Price ID for the Enterprise subscription tier. Pro price ID is required
# above; Enterprise is optional and only needed if you're selling Enterprise.
# STRIPE_ENTERPRISE_PRICE_ID=price_...

# ─── Auto-update (GitHub-backed update service, optional) ─────────────
# Pin updates to an exact commit SHA — empty means "follow main".
# ALLOWED_UPDATE_SHA=
# Require signed commits / version tags before applying an update.
# UPDATE_REQUIRE_SIGNED=false
# UPDATE_REQUIRE_TAG=false

# ─── Tenant migration runner ──────────────────────────────────────────
# Max ms a single tenant migration is allowed to run before being killed.
# Default: 60000 (60s).
# TENANT_MIGRATION_TIMEOUT_MS=60000

# ─── Import scripts (one-off, not used by the running server) ─────────
# scripts/full-import.ts and scripts/reimport-notes.ts read these at runtime.
# They are only relevant when running those scripts directly; the server
# itself never reads RD_* or ADMIN_*.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin123
# SERVER_URL=http://localhost:443
# RD_API_KEY=
# RD_API_URL=https://api.repairdesk.co/api/web/v1
# RD_CLIENT_ID=
# RD_CLIENT_SECRET=

# ─── PM2 process manager (read-only detection) ────────────────────────
# PM2_HOME / pm_id are set by PM2 itself when it spawns the server; they
# are NOT values you set by hand. Listed here for reference only.
# PM2_HOME=

# ─── Legacy single-tenant SMS / SMTP hints (optional) ─────────────────
# These are read ONLY to log whether SMS/SMTP appear "configured" at boot.
# The actual per-tenant credentials live in the tenant DB's store_config.
# SMS_PROVIDER=
# VONAGE_API_KEY=
# TWILIO_ACCOUNT_SID=
# SMTP_HOST=
# SMTP_USER=
# TCX_HOST=
