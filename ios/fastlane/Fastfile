default_platform(:ios)

platform :ios do
  desc "Generate Xcode project from project.yml"
  lane :generate do
    sh("cd .. && xcodegen generate")
  end

  # ── Preflight ────────────────────────────────────────────────────────────
  # Run before ANY lane that uploads to Apple. Catches common blockers early.
  # Usage: bundle exec fastlane preflight
  #        (also called automatically by :beta and :release)
  desc "Pre-flight gate: launch-readiness + smoke checks; blocks upload on failure"
  lane :preflight do
    # 1. Confirm PrivacyInfo.xcprivacy is present and has no tracking domains
    sh("cd .. && scripts/launch-readiness.sh") do |status, result, _|
      UI.user_error!("launch-readiness.sh failed:\n#{result}") unless status.success?
    end

    # 2. SwiftLint — zero errors (warnings allowed)
    sh("cd .. && swiftlint lint --strict --quiet 2>&1 | grep -E 'error:|FAIL' && exit 1; exit 0") do |status, result, _|
      UI.user_error!("SwiftLint errors:\n#{result}") unless status.success?
    end

    # 3. App Review lint (purpose strings, no private APIs, no debug prints,
    #    no hardcoded credentials)
    sh("cd .. && scripts/app-review-lint.sh") do |status, result, _|
      UI.user_error!("app-review-lint failed:\n#{result}") unless status.success?
    end

    # 4. SDK sovereignty
    sh("cd .. && scripts/sdk-ban.sh") do |status, result, _|
      UI.user_error!("sdk-ban.sh failed:\n#{result}") unless status.success?
    end

    UI.success("Preflight passed. Safe to proceed.")
  end

  # ── Test lane (§31) ─────────────────────────────────────────────────────
  # Full §31 test suite: unit + integration + UI.
  #
  # Subsets:
  #   bundle exec fastlane test               # all targets, default device matrix
  #   bundle exec fastlane test only_unit:true
  #   bundle exec fastlane test only_ui:true
  #   bundle exec fastlane test device:"iPhone SE (3rd generation)"
  #
  # CI usage: called by ios-ci.yml after `preflight`. Results land in
  # fastlane/test_output/ (JUnit XML + HTML). Code coverage report is
  # written to fastlane/coverage/ and posted to PR by the CI step.
  #
  # §31 device matrix (subset — full matrix in §31.10):
  #   iPhone SE (3rd generation) — compact, iOS 17
  #   iPhone 16 Pro              — 6.3", iOS 18
  #   iPad Air (M2)              — regular, split-view
  desc "§31 test lane: unit + UI tests with coverage and JUnit output"
  lane :test do |options|
    only_unit = options.fetch(:only_unit, false)
    only_ui   = options.fetch(:only_ui, false)
    device    = options.fetch(:device, "iPhone 16 Pro")
    # §31.9 Flake detection — retry failing tests up to `flake_retries` times.
    # When non-zero, fastlane invokes `xcodebuild -retry-tests-on-failure
    # -test-iterations <flake_retries+1>` so that a test flipping green on
    # retry is surfaced as `flaky` in the JUnit + xcresult output, not as a
    # failure. Override with `flake_retries:0` for hermetic CI runs.
    # Default of 1 matches Apple's recommendation: one retry catches most
    # transient simulator hiccups without masking real regressions.
    flake_retries = options.fetch(:flake_retries, 1).to_i

    # Resolve which test plan to run
    test_plan = if only_unit
      "UnitTests"
    elsif only_ui
      "UITests"
    else
      "AllTests"
    end

    UI.message("§31 running test plan '#{test_plan}' on #{device} " \
               "(flake_retries=#{flake_retries})")

    run_tests(
      scheme:                    "BizarreCRM",
      devices:                   [device],
      testplan:                  test_plan,
      clean:                     true,
      code_coverage:             true,
      output_directory:          "fastlane/test_output",
      output_files:              "junit.xml,report.html",
      result_bundle:             true,
      result_bundle_path:        "fastlane/test_output/BizarreCRM.xcresult",
      fail_build:                true,         # non-zero exit on any failure
      # §31.9 Flake detection — `number_of_retries` is fastlane's wrapper
      # around `xcodebuild -retry-tests-on-failure -test-iterations`.
      # Tests that pass on retry are tagged `flaky` in JUnit + xcresult.
      number_of_retries:         flake_retries,
      xcargs:                    "-maximum-test-execution-time-allowance 60",
    )

    # Extract coverage report to fastlane/coverage/ (xcresulttool available in Xcode 15+)
    sh("xcrun xcresulttool export --type directory " \
       "--path fastlane/test_output/BizarreCRM.xcresult " \
       "--output-path fastlane/coverage/ 2>/dev/null || true")

    UI.success("§31 tests complete. Results in fastlane/test_output/, coverage in fastlane/coverage/")
  end

  # Legacy alias kept for scripts that call the old lane name.
  desc "Run unit tests (alias for :test lane; use :test for full §31 support)"
  lane :tests do
    test(only_unit: true)
  end

  # ── Screenshots ──────────────────────────────────────────────────────────
  # Generates App Store screenshots for all required device sizes + locales.
  # Light and dark variants are produced in two passes.
  # Output lands in fastlane/screenshots/ — commit to match repo.
  # Usage: bundle exec fastlane screenshots
  desc "Generate App Store screenshots via fastlane snapshot (light + dark)"
  lane :screenshots do
    # Pass 1: light mode (UIUserInterfaceStyle = Light)
    capture_screenshots(
      scheme: "BizarreCRM",
      xcargs: "-testPlan ScreenshotTests -launch_arguments '-UIUserInterfaceStyle Light'",
      output_directory: "./fastlane/screenshots/light",
      clear_previous_screenshots: true,
    )

    # Pass 2: dark mode
    capture_screenshots(
      scheme: "BizarreCRM",
      xcargs: "-testPlan ScreenshotTests -launch_arguments '-UIUserInterfaceStyle Dark'",
      output_directory: "./fastlane/screenshots/dark",
      clear_previous_screenshots: true,
    )

    # Frame screenshots with device bezels using frameit
    frame_screenshots(
      white: false,
      path: "./fastlane/screenshots",
    )

    UI.success("Screenshots generated in fastlane/screenshots/. Upload with: fastlane deliver --skip_binary_upload --skip_metadata")
  end

  # ── Beta (TestFlight) ────────────────────────────────────────────────────
  desc "Build + upload a TestFlight beta (runs preflight first)"
  lane :beta do
    preflight
    setup_ci if ENV["CI"]
    match(type: "appstore", readonly: true)
    build_app(
      scheme: "BizarreCRM",
      export_method: "app-store",
      output_directory: "build"
    )
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      changelog: "Latest internal build."
    )
  end

  # ── Release ──────────────────────────────────────────────────────────────
  desc "Build + submit to App Store (runs preflight + screenshots first)"
  lane :release do
    preflight
    screenshots
    setup_ci if ENV["CI"]
    match(type: "appstore", readonly: true)
    build_app(
      scheme: "BizarreCRM",
      export_method: "app-store",
      output_directory: "build"
    )
    deliver(
      submit_for_review: true,
      automatic_release: false,
      phased_release: true,
      force: true,        # skip HTML report prompt in CI
    )
  end
end
