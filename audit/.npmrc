engine-strict=true

# SEC-H111: CI should run installs with --ignore-scripts to block malicious
# postinstall hooks in transitive deps. Uncomment the line below OR prefer
# `npm ci --ignore-scripts` in CI workflow files — the env-scoped flag is
# preferred so dev installs on developer machines still run legitimate
# postinstalls (e.g. native-module prebuild fetches) that the team has
# vetted. If uncommented here, also verify no first-party package needs a
# postinstall to function (e.g. better-sqlite3 prebuild — it doesn't, since
# the native addon ships as a precompiled binary).
#
# ignore-scripts=true
