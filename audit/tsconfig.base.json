{
  // @audit-fixed: Deployment audit (section 34) — sourceMap was true here, which
  // caused the compiled server bundle (packages/server/dist/) to ship .js.map files.
  // Anyone who could reach /admin or otherwise grab dist files could reverse the
  // server source. Source maps stay off in production. If a future build pipeline
  // wants them for error reporting, set sourceMap conditionally per package.
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false
  }
}
