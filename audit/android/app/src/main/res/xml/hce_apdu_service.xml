<?xml version="1.0" encoding="utf-8"?>
<!--
    §17.8 — HCE APDU service descriptor for LoyaltyCardHceService.

    Declares the proprietary AID used for Bizarre CRM loyalty-card emulation:
      F042495A43524D01  (F0 = proprietary prefix, "BIZCRM" ASCII, 01 = version)

    The "payment" category causes Android to show a "tap & pay" disambiguation
    dialog when multiple HCE services are registered.  If we switch to a custom
    category we must use "other" and inform the reader out-of-band.
-->
<host-apdu-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:description="@string/loyalty_hce_description"
    android:requireDeviceUnlock="false">

    <aid-group
        android:description="@string/loyalty_hce_description"
        android:category="other">
        <aid-filter android:name="F042495A43524D01" />
    </aid-group>

</host-apdu-service>
